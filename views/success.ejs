<!-- views/success.ejs -->
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sukses</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold fs-3 brand-name" href="/plans">
        <i class="bi bi-code-slash me-2 text-primary"></i>Auto Order
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/plans">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/plans">Plans</a></li>
          <li class="nav-item"><a class="nav-link" href="/history">Riwayat</a></li>
          <li class="nav-item"><a class="nav-link" href="https://wa.me/<%= owner.wa %>">Kontak</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-md-10">
        <div class="card p-4 p-md-5 shadow-soft border-0">
          <h2 class="fw-bold mb-3 text-center">Pembayaran Berhasil</h2>
          <p class="lead text-center text-secondary mb-4">Terima kasih, pesanan Anda sedang diproses.</p>
          <div id="successContent">
            <div class="text-center">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <p class="mt-2">Mengambil detail pesanan...</p>
            </div>
          </div>
          <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 mt-4">
            <a href="/plans" class="btn btn-primary-custom rounded-pill px-4 py-2">Beli Lagi</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => alert('Disalin!')).catch(() => alert('Gagal'));
    }
    function updateOrderInLocalStorage(order) {
      let orders = JSON.parse(localStorage.getItem('orders') || '[]');
      const idx = orders.findIndex(o => o.id === order.id);
      if (idx !== -1) orders[idx] = order; else orders.push(order);
      localStorage.setItem('orders', JSON.stringify(orders));
    }
    async function loadOrderDetail() {
      const orderId = new URLSearchParams(window.location.search).get('orderId');
      if (!orderId) {
        document.getElementById('successContent').innerHTML = '<p class="text-danger">ID pesanan tidak ditemukan.</p>';
        return;
      }
      try {
        const res = await fetch(`/api/order/${orderId}/detail`);
        if (!res.ok) throw new Error('Gagal ambil detail');
        const order = await res.json();
        updateOrderInLocalStorage(order);

        let html = '';
        if (order.isPanel && order.panelCredentials) {
          html = `
            <div class="card mt-4 p-4" style="background:#f8faff; border:1px solid #d9e9ff;">
              <h5 class="text-primary mb-3"><i class="bi bi-server me-2"></i>Detail Panel</h5>
              <div class="mb-2 d-flex flex-wrap align-items-center gap-2">
                <strong>Username:</strong> <span class="bg-white p-1 px-3 rounded-pill border">${order.panelCredentials.username}</span>
                <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyToClipboard('${order.panelCredentials.username}')">Copy</button>
              </div>
              <div class="mb-2 d-flex flex-wrap align-items-center gap-2">
                <strong>Email:</strong> <span class="bg-white p-1 px-3 rounded-pill border">${order.panelCredentials.email}</span>
                <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyToClipboard('${order.panelCredentials.email}')">Copy</button>
              </div>
              <div class="mb-2 d-flex flex-wrap align-items-center gap-2">
                <strong>Password:</strong> <span class="bg-white p-1 px-3 rounded-pill border">${order.panelCredentials.password}</span>
                <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyToClipboard('${order.panelCredentials.password}')">Copy</button>
              </div>
              <p class="mt-3 mb-0"><strong>Login:</strong> <a href="${order.panelCredentials.domain}" target="_blank" class="text-primary">${order.panelCredentials.domain}</a></p>
              <p class="text-warning mt-3 small"><i class="bi bi-exclamation-triangle-fill me-1"></i>Simpan info ini! Password tidak muncul lagi.</p>
            </div>`;
        } else if (order.isPanel && order.panelError) {
          html = `<div class="alert alert-danger mt-3"><h5>Gagal membuat panel</h5><p>${order.panelError}</p><p>Hubungi owner.</p></div>`;
        } else if (order.isGroup) {
          html = `
            <div class="alert mt-4" style="background-color: #d4f0d4; border-color: #b8e0b8;">
              <h5 class="text-success"><i class="bi bi-whatsapp me-2"></i>Akses Grup</h5>
              <p>Klik tombol di bawah untuk bergabung ke grup eksklusif:</p>
              <a href="${order.groupLink}" target="_blank" class="btn btn-success rounded-pill px-4 py-2">
                <i class="bi bi-whatsapp me-2"></i>Join Grup
              </a>
            </div>`;
        }
        document.getElementById('successContent').innerHTML = html;
      } catch (err) {
        document.getElementById('successContent').innerHTML = `<p class="text-danger">Error: ${err.message}</p>`;
      }
    }
    loadOrderDetail();
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>