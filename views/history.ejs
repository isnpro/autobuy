<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Riwayat Transaksi</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/style.css">
  <style>
    .modal-backdrop {
      display: none !important;
    }
    @media (max-width: 576px) {
      .table thead {
        display: none;
      }
      .table tbody tr {
        display: block;
        margin-bottom: 1rem;
        border: 1px solid #dee2e6;
        border-radius: 1rem;
        padding: 0.5rem;
      }
      .table tbody td {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem;
        border: none;
        border-bottom: 1px solid #eee;
      }
      .table tbody td:last-child {
        border-bottom: none;
      }
      .table tbody td::before {
        content: attr(data-label);
        font-weight: bold;
        width: 40%;
        text-align: left;
      }
      .table tbody td > * {
        width: 60%;
        text-align: right;
      }
      .table tbody td[data-label="Aksi"] {
        justify-content: center;
        padding: 0.5rem 0;
      }
      .table tbody td[data-label="Aksi"]::before {
        display: none;
      }
      .table tbody td[data-label="Aksi"] > * {
        width: auto;
        text-align: center;
        margin: 0 auto;
      }
      .table tbody td .btn-sm {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        white-space: nowrap;
        min-width: 80px;
      }
      .table tbody td .badge {
        display: inline-block;
        width: auto;
        min-width: 70px;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold fs-3 brand-name" href="/plans">
        <i class="bi bi-code-slash me-2 text-primary"></i>Auto Order
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/plans">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/plans">Plans</a></li>
          <li class="nav-item"><a class="nav-link" href="/history">Riwayat</a></li>
          <li class="nav-item"><a class="nav-link" href="https://wa.me/<%= owner.wa %>">Kontak</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-5">
    <h1 class="text-center main-title mb-5">Riwayat Transaksi</h1>
    <div id="historyContent"></div>
    <div class="text-center mt-4">
      <a href="/plans" class="btn btn-outline-primary rounded-pill px-4 py-2">Kembali ke Beranda</a>
    </div>
  </div>

  <script>
    function copyText(text) {
      navigator.clipboard.writeText(text).then(() => alert('Teks berhasil disalin!')).catch(() => alert('Gagal menyalin teks.'));
    }

    function displayHistory() {
      let orders = JSON.parse(localStorage.getItem('orders') || '[]');
      orders.sort((a, b) => b.createdAt - a.createdAt);
      const container = document.getElementById('historyContent');

      if (orders.length === 0) {
        container.innerHTML = '<div class="alert alert-info text-center">Belum ada transaksi.</div>';
        return;
      }

      let tableHtml = `
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>ID Order</th>
                <th>Paket</th>
                <th>Harga</th>
                <th>Status</th>
                <th>Tanggal</th>
                <th class="text-center">Aksi</th>
              </tr>
            </thead>
            <tbody>
      `;

      orders.forEach(order => {
        const date = new Date(order.createdAt).toLocaleString('id-ID');
        let statusBadge = '';
        if (order.status === 'pending') statusBadge = '<span class="badge bg-warning text-dark">Pending</span>';
        else if (order.status === 'success') statusBadge = '<span class="badge bg-success">Sukses</span>';
        else if (order.status === 'cancelled') statusBadge = '<span class="badge bg-danger">Dibatalkan</span>';

        let actionButton = '';
        if (order.status === 'success' && order.panelCredentials) {
          actionButton = `
            <button class="btn btn-sm btn-outline-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#detailModal${order.id}">
              Detail
            </button>
          `;
        } else if (order.isGroup && order.status === 'success') {
          actionButton = `
            <button class="btn btn-sm btn-outline-success rounded-pill" data-bs-toggle="modal" data-bs-target="#groupModal${order.id}">
              Grup
            </button>
          `;
        }

        tableHtml += `
          <tr>
            <td data-label="ID Order"><code class="text-break">${order.id}</code></td>
            <td data-label="Paket">${order.name}</td>
            <td data-label="Harga">Rp ${order.price.toLocaleString('id-ID')}</td>
            <td data-label="Status">${statusBadge}</td>
            <td data-label="Tanggal">${date}</td>
            <td data-label="Aksi" class="text-center">${actionButton}</td>
          </tr>
        `;
      });

      tableHtml += `</tbody></table></div>`;

      orders.forEach(order => {
        if (order.status === 'success' && order.panelCredentials) {
          tableHtml += `
            <div class="modal fade" id="detailModal${order.id}" tabindex="-1" aria-labelledby="detailModalLabel${order.id}" aria-hidden="true" data-bs-backdrop="false">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                  <div class="modal-header" style="background: var(--gradient-main); color: white;">
                    <h5 class="modal-title" id="detailModalLabel${order.id}">Detail Panel</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <div class="mb-3 d-flex flex-wrap align-items-center gap-2">
                      <strong class="me-2">Username:</strong>
                      <span class="bg-light p-1 px-3 rounded-pill">${order.panelCredentials.username}</span>
                      <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyText('${order.panelCredentials.username}')">Copy</button>
                    </div>
                    <div class="mb-3 d-flex flex-wrap align-items-center gap-2">
                      <strong class="me-2">Email:</strong>
                      <span class="bg-light p-1 px-3 rounded-pill">${order.panelCredentials.email}</span>
                      <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyText('${order.panelCredentials.email}')">Copy</button>
                    </div>
                    <div class="mb-3 d-flex flex-wrap align-items-center gap-2">
                      <strong class="me-2">Password:</strong>
                      <span class="bg-light p-1 px-3 rounded-pill">${order.panelCredentials.password}</span>
                      <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyText('${order.panelCredentials.password}')">Copy</button>
                    </div>
                    <p class="mt-3 mb-0">
                      <strong>Login URL:</strong> 
                      <a href="${order.panelCredentials.domain}" target="_blank" class="text-primary text-break">${order.panelCredentials.domain}</a>
                    </p>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                  </div>
                </div>
              </div>
            </div>
          `;
        } else if (order.isGroup && order.status === 'success') {
          tableHtml += `
            <div class="modal fade" id="groupModal${order.id}" tabindex="-1" aria-labelledby="groupModalLabel${order.id}" aria-hidden="true" data-bs-backdrop="false">
              <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                  <div class="modal-header" style="background: #28a745; color: white;">
                    <h5 class="modal-title" id="groupModalLabel${order.id}">Akses Grup</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body text-center">
                    <p>Klik tombol di bawah untuk bergabung ke grup eksklusif:</p>
                    <a href="${order.groupLink}" target="_blank" class="btn btn-success rounded-pill px-4 py-2">
                      <i class="bi bi-whatsapp me-2"></i>Join Grup
                    </a>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
                  </div>
                </div>
              </div>
            </div>
          `;
        }
      });

      container.innerHTML = tableHtml;
    }

    displayHistory();
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>