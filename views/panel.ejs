<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pilih Ukuran Panel</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold fs-3 brand-name" href="/plans">
        <i class="bi bi-code-slash me-2 text-primary"></i>Auto Order
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="/plans">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/plans">Plans</a></li>
          <li class="nav-item"><a class="nav-link" href="/history">Riwayat</a></li>
          <li class="nav-item"><a class="nav-link" href="https://wa.me/<%= owner.wa %>">Kontak</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-5">
    <h1 class="text-center main-title mb-5">Pilih Ukuran Panel</h1>
    <div class="row g-4">
      <% 
        const sizeOrder = ['UNLI', '1GB', '2GB', '3GB', '4GB', '5GB', '6GB', '7GB', '8GB', '9GB', '10GB'];
        sizeOrder.forEach(size => {
          if (!panelSizes[size]) return;
          const isUnli = size === 'UNLI';
          const price = isUnli ? unliPrice : parseInt(size) * pricePerGb;
          let specItems;
          if (isUnli) {
            specItems = ['RAM Unlimited', 'Disk Unlimited', 'CPU Unlimited'];
          } else {
            const specsStr = `${panelSizes[size].ram} MB RAM, ${panelSizes[size].disk} MB Disk, ${panelSizes[size].cpu}% CPU`;
            specItems = specsStr.split(', ');
          }
      %>
      <div class="col-md-4 d-flex">
        <div class="card p-4 w-100 text-center shadow-hover position-relative d-flex flex-column">
          <% if (isUnli) { %>
            <div class="position-absolute top-0 end-0 bg-danger text-white px-3 py-1 rounded-bl-lg rounded-tr-lg fw-bold" style="border-radius: 0 1.5rem 0 1.5rem;">PROMO</div>
          <% } %>
          <h5 class="fw-bold mt-2"><%= size %></h5>
          <div class="server-specs my-3 flex-grow-1">
            <% specItems.forEach(item => {
              let icon = 'bi-info-circle';
              if (item.toLowerCase().includes('ram')) icon = 'bi-memory';
              else if (item.toLowerCase().includes('disk')) icon = 'bi-hdd';
              else if (item.toLowerCase().includes('cpu')) icon = 'bi-cpu';
            %>
            <div class="spec-item"><i class="bi <%= icon %>"></i> <%= item %></div>
            <% }) %>
          </div>
          <div class="price-rp mb-3">Rp <%= price.toLocaleString('id-ID') %> <span class="text-secondary fs-6">/bulan</span></div>
          <a href="/checkout/<%= size %>" class="btn btn-outline-primary rounded-pill mt-auto">Pilih</a>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="text-center mt-4">
      <a href="/plans" class="btn btn-outline-secondary rounded-pill">Kembali</a>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>